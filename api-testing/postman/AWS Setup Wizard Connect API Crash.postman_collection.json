    {
      "name": "MissingAccessKey",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Tests for MissingAccessKey request",
              "// Validates status code, JSON shape, and key fields in the response",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Validate response body is valid JSON",
              "let json;",
              "pm.test(\"Response body is valid JSON\", function () {",
              "    try {",
              "        json = pm.response.json();",
              "        pm.expect(json).to.be.an(\"object\");",
              "    } catch (e) {",
              "        // Fail the test explicitly if JSON parsing throws",
              "        pm.expect.fail(\"Response is not valid JSON: \" + e.message);",
              "    }",
              "});",
              "",
              "// Only proceed with further checks if json is parsed",
              "if (typeof json === 'object' && json) {",
              "    // response.status.isSuccess is boolean and false",
              "    pm.test(\"status.isSuccess is boolean and false\", function () {",
              "        pm.expect(json).to.have.property(\"status\").that.is.an(\"object\");",
              "        pm.expect(json.status).to.have.property(\"isSuccess\").that.is.a(\"boolean\");",
              "        pm.expect(json.status.isSuccess).to.eql(false);",
              "    });",
              "",
              "    // response.status.status equals 'INVALID'",
              "    pm.test(\"status.status equals 'INVALID'\", function () {",
              "        pm.expect(json.status).to.have.property(\"status\").that.is.a(\"string\");",
              "        pm.expect(json.status.status).to.eql(\"INVALID\");",
              "    });",
              "",
              "    // response.status.recordAlias equals the request body alias",
              "    pm.test(\"recordAlias equals request alias\", function () {",
              "        // Parse request body safely",
              "        let reqBody;",
              "        try {",
              "            reqBody = pm.request.body && pm.request.body.raw ? JSON.parse(pm.request.body.raw) : {};",
              "        } catch(e) {",
              "            reqBody = {};",
              "        }",
              "        const expectedAlias = reqBody && typeof reqBody.alias === 'string' ? reqBody.alias : undefined;",
              "        pm.expect(json.status).to.have.property(\"recordAlias\");",
              "        if (expectedAlias !== undefined) {",
              "            pm.expect(json.status.recordAlias).to.eql(expectedAlias);",
              "        } else {",
              "            pm.expect.fail(\"Request body alias not found to compare against recordAlias\");",
              "        }",
              "    });",
              "",
              "    // response contains operationError string when isSuccess is false",
              "    pm.test(\"operationError present when isSuccess is false\", function () {",
              "        if (json.status && json.status.isSuccess === false) {",
              "            pm.expect(json.status).to.have.property(\"operationError\");",
              "            pm.expect(json.status.operationError).to.be.a(\"string\").and.not.empty;",
              "        } else {",
              "            pm.expect(true).to.be.true; // not applicable",
              "        }",
              "    });",
              "}",
              "",
              "// Warn (non-failing) if secretKey or accessKey in request body are empty",
              "pm.test(\"Warning when accessKey/secretKey are empty (non-failing)\", function () {",
              "    let reqBody = {};",
              "    try {",
              "        reqBody = pm.request.body && pm.request.body.raw ? JSON.parse(pm.request.body.raw) : {};",
              "    } catch(e) {}",
              "    const hasEmptyAccess = typeof reqBody.accessKey === 'string' && reqBody.accessKey.trim() === '';",
              "    const hasEmptySecret = typeof reqBody.secretKey === 'string' && reqBody.secretKey.trim() === '';",
              "",
              "    if (hasEmptyAccess || hasEmptySecret) {",
              "        // Mark as a warning by adding to test output without failing the run",
              "        pm.test(\"WARN: One or both credentials are empty\", function() {",
              "            pm.expect(true).to.be.true;",
              "        });",
              "        pm.environment.set(\"__credentials_warning\", \"accessKey:\" + (hasEmptyAccess ? \"empty\" : \"set\") + \", secretKey:\" + (hasEmptySecret ? \"empty\" : \"set\"));",
              "    } else {",
              "        pm.environment.unset(\"__credentials_warning\");",
              "        pm.expect(true).to.be.true;",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
