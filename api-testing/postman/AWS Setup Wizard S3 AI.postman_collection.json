    {
      "name": "Valid baseline request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has 'totalReports' as a number\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property('totalReports');\r",
              "    pm.expect(jsonData.totalReports).to.be.a('number');\r",
              "});"
            ],
